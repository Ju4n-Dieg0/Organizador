DATABASE_URL=postgresql://organizador:organizador@localhost:5432/organizador?schema=public
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=7d

# Usuario admin por defecto (se siembra con `npx prisma db seed`)
DEFAULT_ADMIN_EMAIL=admin@togrowagencia.com
DEFAULT_ADMIN_PASSWORD=cambia-esta-contrasena
DEFAULT_ADMIN_NAME=Admin

# Telegram (vacio = bot y recordatorios desactivados, la app arranca igual)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# Cron de recordatorios (default: todos los dias 9:00)
REMINDER_CRON=0 9 * * *

# LM Studio (vacio = modo conversacional del bot desactivado, la app arranca igual)
# LMSTUDIO_MODEL: usar el identificador de la API (GET /v1/models), NO el nombre
# de display (ej. meta-llama-3.1-8b-instruct, no "Meta Llama 3.1 8B Instruct")
LMSTUDIO_BASE_URL=
LMSTUDIO_MODEL=
# Timeout por peticion en ms (default 90000; subir en hardware lento)
LMSTUDIO_TIMEOUT_MS=
